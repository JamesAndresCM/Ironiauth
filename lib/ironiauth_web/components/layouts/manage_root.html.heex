<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="csrf-token" content={Plug.CSRFProtection.get_csrf_token()} />
  <title>Admin Panel · Ironiauth</title>
  <script defer src={~p"/assets/app.js"}></script>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f1f5f9;color:#1e293b}
    a{color:inherit;text-decoration:none}

    /* Layout */
    .m-layout{display:flex;min-height:100vh}
    .m-sidebar{width:220px;background:#1e1b4b;display:flex;flex-direction:column;flex-shrink:0;position:fixed;top:0;left:0;height:100vh;z-index:10}
    .m-body{margin-left:220px;flex:1;display:flex;flex-direction:column;min-height:100vh}
    .m-topbar{background:white;border-bottom:1px solid #e2e8f0;padding:.875rem 1.5rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:5}
    .m-content{padding:1.5rem;flex:1}

    /* Sidebar */
    .m-brand{padding:1.25rem 1.5rem;color:white;font-size:1rem;font-weight:700;border-bottom:1px solid #312e81}
    .m-brand small{display:block;color:#a5b4fc;font-size:.7rem;font-weight:400;margin-top:.2rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .m-nav{padding:.75rem 0;flex:1}
    .m-nav a{display:flex;align-items:center;gap:.5rem;padding:.55rem 1.5rem;color:#c7d2fe;font-size:.85rem;transition:all .15s}
    .m-nav a:hover{background:#312e81;color:white}
    .m-nav a.active{background:#4f46e5;color:white;font-weight:500}
    .m-nav-icon{font-size:1rem;width:1.25rem;text-align:center}
    .m-sidebar-footer{padding:1rem 1.5rem;border-top:1px solid #312e81}

    /* Topbar */
    .m-topbar-company{font-weight:600;font-size:.9rem;color:#1e293b}
    .m-topbar-user{font-size:.8rem;color:#64748b}
    .m-topbar-actions{display:flex;align-items:center;gap:.75rem}

    /* Cards */
    .m-card{background:white;border-radius:8px;padding:1.25rem;box-shadow:0 1px 3px rgba(0,0,0,.08);margin-bottom:1rem}
    .m-card-title{font-size:.95rem;font-weight:600;color:#1e293b;margin-bottom:1rem;padding-bottom:.75rem;border-bottom:1px solid #f1f5f9}

    /* Stats */
    .m-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1rem;margin-bottom:1.5rem}
    .m-stat{background:white;border-radius:8px;padding:1.25rem;box-shadow:0 1px 3px rgba(0,0,0,.08);text-align:center}
    .m-stat-n{font-size:2rem;font-weight:700;color:#4f46e5}
    .m-stat-l{font-size:.7rem;color:#64748b;text-transform:uppercase;letter-spacing:.05em;margin-top:.25rem}

    /* Tables */
    .m-table{width:100%;border-collapse:collapse}
    .m-table th{text-align:left;padding:.5rem .75rem;font-size:.7rem;text-transform:uppercase;letter-spacing:.05em;color:#64748b;border-bottom:2px solid #e2e8f0}
    .m-table td{padding:.7rem .75rem;border-bottom:1px solid #f1f5f9;font-size:.875rem;vertical-align:middle}
    .m-table tr:last-child td{border-bottom:none}
    .m-table tr:hover td{background:#fafafa}

    /* Buttons */
    .m-btn{display:inline-flex;align-items:center;gap:.3rem;padding:.45rem .9rem;background:#4f46e5;color:white;border:none;border-radius:6px;font-size:.8rem;font-weight:500;cursor:pointer;transition:background .15s}
    .m-btn:hover{background:#4338ca}
    .m-btn-sm{padding:.25rem .6rem;font-size:.75rem}
    .m-btn-danger{background:#ef4444}
    .m-btn-danger:hover{background:#dc2626}
    .m-btn-ghost{background:transparent;color:#4f46e5;border:1px solid #4f46e5}
    .m-btn-ghost:hover{background:#eff6ff}

    /* Forms */
    .m-form{display:flex;gap:.5rem;align-items:flex-end;flex-wrap:wrap}
    .m-input{padding:.45rem .75rem;border:1px solid #d1d5db;border-radius:6px;font-size:.875rem;outline:none}
    .m-input:focus{border-color:#4f46e5;box-shadow:0 0 0 2px rgba(79,70,229,.1)}
    .m-label{font-size:.75rem;font-weight:500;color:#374151;margin-bottom:.25rem;display:block}

    /* Tags */
    .m-tag{display:inline-block;padding:.1rem .5rem;background:#ede9fe;color:#5b21b6;border-radius:9999px;font-size:.75rem;margin:.1rem}
    .m-tag-green{background:#d1fae5;color:#065f46}

    /* Alerts */
    .m-alert-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca;padding:.65rem 1rem;border-radius:6px;margin-bottom:1rem;font-size:.85rem}
    .m-alert-success{background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;padding:.65rem 1rem;border-radius:6px;margin-bottom:1rem;font-size:.85rem}

    /* Login page */
    .m-login-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;background:#f1f5f9}
    .m-login-card{background:white;border-radius:12px;padding:2rem;width:100%;max-width:400px;box-shadow:0 4px 24px rgba(0,0,0,.1)}
    .m-login-header{text-align:center;margin-bottom:1.5rem}
    .m-login-header h1{font-size:1.5rem;font-weight:700;color:#4f46e5}
    .m-login-header p{color:#64748b;font-size:.85rem;margin-top:.25rem}
    .m-field{margin-bottom:1rem}
    .m-field label{display:block;font-size:.85rem;font-weight:500;color:#374151;margin-bottom:.375rem}
    .m-field input{width:100%;padding:.625rem .75rem;border:1px solid #d1d5db;border-radius:6px;font-size:.875rem;outline:none}
    .m-field input:focus{border-color:#4f46e5;box-shadow:0 0 0 2px rgba(79,70,229,.1)}
    .m-field input:autofocus{border-color:#4f46e5}

    /* Empty state */
    .m-empty{text-align:center;padding:2rem;color:#94a3b8;font-size:.875rem}

    /* Section heading */
    .m-page-title{font-size:1.125rem;font-weight:700;color:#1e293b;margin-bottom:1.25rem}

    /* Divider */
    .m-divider{border:none;border-top:1px solid #e2e8f0;margin:1rem 0}

    /* Pagination */
    .m-pagination{display:flex;align-items:center;gap:.75rem;justify-content:flex-end;padding:.75rem 0 0}
    .m-pagination span{font-size:.85rem;color:#64748b}
    .m-pagination button{padding:.3rem .7rem;border:1px solid #e2e8f0;background:white;border-radius:5px;cursor:pointer;font-size:.8rem;color:#374151}
    .m-pagination button:hover:not([disabled]){background:#f1f5f9}
    .m-pagination button[disabled]{opacity:.4;cursor:default}
  </style>
</head>
<body>
  <%= @inner_content %>
</body>
</html>
